{
  "separate-pull-requests": true,
  "include-component-in-tag": true,
  "include-v-in-tag": true,
  "tag-separator": "-",
  "packages": {
    "ports/blinky": {
      "path": "ports/blinky",
      "changelog-path": "CHANGELOG.md",
      "release-type": "simple",
      "component": "blinky",
      "extra-files": [
        {
          "type": "json",
          "path": "vcpkg.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "ports/hal-interface": {
      "path": "ports/hal-interface",
      "changelog-path": "CHANGELOG.md",
      "release-type": "simple",
      "component": "hal-interface",
      "extra-files": [
        {
          "type": "json",
          "path": "vcpkg.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "ports/stm-hal": {
      "path": "ports/stm-hal",
      "changelog-path": "CHANGELOG.md",
      "release-type": "simple",
      "component": "stm-hal",
      "extra-files": [
        {
          "type": "json",
          "path": "vcpkg.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
