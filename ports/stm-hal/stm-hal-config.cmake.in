@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Find hal-interface dependency
find_dependency(hal-interface REQUIRED)

# Include the targets file
include("${CMAKE_CURRENT_LIST_DIR}/stm-hal-targets.cmake")

# HAL Implementation Information
set(HAL_IMPL_NAME "STM32 HAL" CACHE STRING "HAL implementation name")
set(HAL_TARGET_MCU "STM32U031 (Cortex-M0+)" CACHE STRING "Target MCU description")
set(HAL_TARGET_ARCH "arm" CACHE STRING "Target architecture")

# Compiler definitions required by this HAL
set(HAL_COMPILE_DEFINITIONS
    STM32U031xx
    USE_HAL_DRIVER
    CACHE STRING "HAL-specific compile definitions")

# Linker scripts and startup code
set(HAL_LINKER_SCRIPT "${CMAKE_CURRENT_LIST_DIR}/STM32U031xx_FLASH.ld" CACHE FILEPATH "Default linker script")
set(HAL_LINKER_SCRIPT_FLASH "${CMAKE_CURRENT_LIST_DIR}/STM32U031xx_FLASH.ld" CACHE FILEPATH "Flash linker script")
set(HAL_LINKER_SCRIPT_RAM "${CMAKE_CURRENT_LIST_DIR}/STM32U031xx_RAM.ld" CACHE FILEPATH "RAM linker script")
set(HAL_STARTUP_ASM "${CMAKE_CURRENT_LIST_DIR}/startup_stm32u031xx.s" CACHE FILEPATH "Startup assembly file")

# Legacy variable names for backward compatibility
set(stm-hal_LINKER_SCRIPT_FLASH "${HAL_LINKER_SCRIPT_FLASH}")
set(stm-hal_LINKER_SCRIPT_RAM "${HAL_LINKER_SCRIPT_RAM}")
set(stm-hal_STARTUP_ASM "${HAL_STARTUP_ASM}")

check_required_components(stm-hal)
